# Foundry — CurseForge packager metadata.
#
# The addon lives at the repo root (Foundry-1.0.toc + Foundry.lua + Modules/) and
# packages as Foundry-1.0/ — the same flat layout as the studio's other addons
# (Homestead, Triage, BawrSpam). CurseForge's server-side packager reads the
# version from a root <package-as>/<package-as>.toc, so the addon must be at the
# repo root with a matching TOC (an earlier subfolder + move-folders layout failed
# CF packaging with "could not extract api versions in TOC files").

package-as: Foundry-1.0

enable-nolib-creation: no

# Foundry embeds no libraries — no externals.

# RELEASE_NOTES.html is generated at CI time (extracted from CHANGELOG.md and
# converted from markdown to HTML by the release workflow). CF's API claims to
# accept changelogType: markdown but renders it as plain text; HTML is the only
# format that renders correctly on both CurseForge and Wago.
manual-changelog:
  filename: RELEASE_NOTES.html
  markup-type: html

# Repo-meta files: keep out of the packaged addon. LICENSE ships inside
# the addon (root LICENSE -> Foundry-1.0/LICENSE in the zip). There is no
# Dev-only in-game self-test directory in this repo (FND-012) — those files
# live in the private Foundry_Dev/Foundry-1.0-Dev/ companion addon instead,
# so a packaged release can never reference a file the packager stripped.
ignore:
  - .github
  - .gitignore
  - Foundry-1.0_DevBuild.toc
  - .gitattributes
  - .luacheckrc
  - .pkgmeta
  - .wiki
  - README.md
  - CHANGELOG.md
  - RELEASE_NOTES.html
  - Tests
